<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- ══════════════════════════════════════════════════
         URL Rewrite Rules
         Order matters: API proxy MUST come before SPA fallback
    ══════════════════════════════════════════════════ -->
    <rewrite>
      <rules>

        <!-- ─── 1. Reverse-proxy: /api/* → Node.js on port 8000 ─── -->
        <!-- The backend already uses /api/ prefixes, so no path rewrite needed -->
        <rule name="API Reverse Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:8000/api/{R:1}" />
        </rule>

        <!-- ─── 2. SPA Fallback: all non-file requests → index.html ─── -->
        <!-- Ensures React Router client-side routes work on hard refresh/direct URL -->
        <rule name="React SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>

      </rules>
    </rewrite>

    <!-- ══════════════════════════════════════════════════
         MIME Types
         IIS does not serve unknown extensions by default
    ══════════════════════════════════════════════════ -->
    <staticContent>
      <remove fileExtension=".json"  />
      <mimeMap fileExtension=".json"  mimeType="application/json"       />
      <remove fileExtension=".woff"  />
      <mimeMap fileExtension=".woff"  mimeType="font/woff"              />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2"             />
      <remove fileExtension=".svg"   />
      <mimeMap fileExtension=".svg"   mimeType="image/svg+xml"          />
      <remove fileExtension=".webp"  />
      <mimeMap fileExtension=".webp"  mimeType="image/webp"             />
      <remove fileExtension=".js"    />
      <mimeMap fileExtension=".js"    mimeType="application/javascript" />
    </staticContent>

    <!-- ══════════════════════════════════════════════════
         Enable IIS ARR / Reverse Proxy plumbing
    ══════════════════════════════════════════════════ -->
    <proxy enabled="true" />

    <!-- Kernel cache (static assets only – proxied responses are excluded automatically) -->
    <caching enabled="true" enableKernelCache="true" />

  </system.webServer>

  <!-- ══════════════════════════════════════════════════
       Cache-Control Headers per path
  ══════════════════════════════════════════════════ -->

  <!-- index.html — NEVER cache.
       Must always be fresh so the browser picks up the latest hashed asset filenames. -->
  <location path="index.html">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
          <add name="Pragma"        value="no-cache" />
          <add name="Expires"       value="0" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <!-- Vite hashed assets — cache 1 year (immutable).
       Vite fingerprints every file in /assets/ (e.g. index-Dz9rBkHW.js),
       so a new build always yields new filenames → stale caches are never a problem. -->
  <location path="assets">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <!-- manifest / PWA files — short cache -->
  <location path="manifest.json">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
          <add name="Pragma"        value="no-cache" />
          <add name="Expires"       value="0" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

</configuration>
